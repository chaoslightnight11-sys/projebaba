generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CLINIC_OWNER
  MANAGER
  DOCTOR
  ASSISTANT
  ACCOUNTANT
  RECEPTIONIST
}

enum Gender {
  FEMALE
  MALE
  OTHER
  UNSPECIFIED
}

enum PatientTag {
  NEW
  ACTIVE
  PASSIVE
  RISKY
  VIP
}

enum AppointmentStatus {
  PENDING_CONFIRMATION
  PLANNED
  ARRIVED
  NO_SHOW
  CANCELLED
  COMPLETED
}

enum TreatmentStatus {
  PROPOSED
  ACCEPTED
  STARTED
  COMPLETED
  CANCELLED
}

enum PaymentType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  ONLINE
}

enum PaymentStatus {
  PAID
  PENDING
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ConsentStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum CommunicationChannel {
  WHATSAPP
  SMS
  EMAIL
  PHONE
}

enum CommunicationStatus {
  QUEUED
  SENT
  FAILED
}

enum CommunicationDirection {
  OUTBOUND
  INBOUND
}

enum RecallStatus {
  OPEN
  CONTACTED
  SCHEDULED
  CLOSED
}

enum TourismLeadSourceChannel {
  WEB_FORM
  WHATSAPP
  INSTAGRAM_DM
  MANUAL
  N8N_WEBHOOK
  AIRTABLE
}

enum TourismLeadStatus {
  NEW
  CONTACTED
  WAITING_REPLY
  QUALIFIED
  PACKAGE_SENT
  BOOKED
  TREATMENT_STARTED
  TREATMENT_COMPLETED
  LOST
}

enum TourismCurrency {
  EUR
  USD
  GBP
  TRY
}

enum TourismPackageStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ReservationShareChannel {
  N8N
  EMAIL
  WHATSAPP
  MANUAL
}

enum ReservationShareStatus {
  PENDING
  SENT
  CONFIRMED
  FAILED
}

enum LeadFollowUpStatus {
  ACTIVE
  PAUSED
  COMPLETED
  STOPPED
}

enum PostTreatmentFollowUpStatus {
  SCHEDULED
  SENT
  REPLIED
  ISSUE_REPORTED
  COMPLETED
}

enum ReviewPlatform {
  GOOGLE
  TRUSTPILOT
  CUSTOM
}

enum ReviewRequestStatus {
  SCHEDULED
  SENT
  CLICKED
  COMPLETED
  FAILED
}

enum BeforeAfterStatus {
  DRAFT
  APPROVED
  PUBLISHED_WEBSITE
  PUBLISHED_SOCIAL
  ARCHIVED
}

enum DigitalConsentStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  DECLINED
  EXPIRED
}

enum TourismSurveySource {
  WHATSAPP
  EMAIL
  WEB_LINK
}

enum ChatbotCategory {
  PRICE
  DURATION
  VISA
  HOTEL
  TRANSFER
  TREATMENT
  APPOINTMENT
  GENERAL
}

enum ChatConversationChannel {
  WEBSITE
  WHATSAPP
  INSTAGRAM
}

enum ChatConversationStatus {
  BOT_HANDLED
  HUMAN_NEEDED
  CLOSED
}

enum ChatMessageSender {
  BOT
  PATIENT
  HUMAN
}

enum NotificationType {
  LEAD
  PACKAGE
  FOLLOW_UP
  POST_TREATMENT
  REVIEW
  SURVEY
  ISSUE
  SYSTEM
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum IntegrationProvider {
  N8N
  AIRTABLE
  WHATSAPP
  INSTAGRAM
  EMAIL
  SMS
  GOOGLE_REVIEW
  TRUSTPILOT
  PAYMENT
}

enum IntegrationLogStatus {
  SUCCESS
  FAILED
  PENDING
}

model Organization {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  plan            String             @default("Klinik")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  branches        Branch[]
  users           User[]
  patients        Patient[]
  appointments    Appointment[]
  treatmentPlans  TreatmentPlan[]
  treatments      Treatment[]
  payments        Payment[]
  invoices        Invoice[]
  stockItems      StockItem[]
  stockMovements  StockMovement[]
  staff           Staff[]
  consents        Consent[]
  surveys         Survey[]
  surveyResponses SurveyResponse[]
  communication   CommunicationLog[]
  recalls         Recall[]
  reports         ReportSnapshot[]
  demoRequests    DemoRequest[]
  auditLogs       AuditLog[]
}

model Branch {
  id              String             @id @default(cuid())
  name            String
  city            String
  address         String?
  phone           String?
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  users           User[]
  patients        Patient[]
  appointments    Appointment[]
  treatmentPlans  TreatmentPlan[]
  treatments      Treatment[]
  payments        Payment[]
  invoices        Invoice[]
  stockItems      StockItem[]
  stockMovements  StockMovement[]
  staff           Staff[]
  consents        Consent[]
  surveys         Survey[]
  surveyResponses SurveyResponse[]
  communication   CommunicationLog[]
  recalls         Recall[]
  reports         ReportSnapshot[]
  auditLogs       AuditLog[]

  @@index([organizationId])
}

model User {
  id                  String          @id @default(cuid())
  name                String
  email               String          @unique
  passwordHash        String
  role                Role
  active              Boolean         @default(true)
  organizationId      String
  branchId            String?
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch              Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  doctorAppointments  Appointment[]   @relation("DoctorAppointments")
  doctorPlans         TreatmentPlan[] @relation("DoctorPlans")
  doctorTreatments    Treatment[]     @relation("DoctorTreatments")
  auditLogs           AuditLog[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([role])
}

model Patient {
  id              String             @id @default(cuid())
  firstName       String
  lastName        String
  nationalId      String?
  phone           String
  email           String?
  birthDate       DateTime?
  gender          Gender             @default(UNSPECIFIED)
  address         String?
  allergies       String?
  chronicDiseases String?
  notes           String?
  tag             PatientTag         @default(NEW)
  lastVisitAt     DateTime?
  organizationId  String
  branchId        String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  treatmentPlans  TreatmentPlan[]
  treatments      Treatment[]
  payments        Payment[]
  invoices        Invoice[]
  consents        Consent[]
  surveyResponses SurveyResponse[]
  communication   CommunicationLog[]
  recalls         Recall[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([phone])
  @@index([tag])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  startsAt        DateTime
  durationMinutes Int               @default(30)
  room            String?
  treatmentType   String
  status          AppointmentStatus @default(PLANNED)
  notes           String?
  organizationId  String
  branchId        String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Restrict)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId, startsAt])
  @@index([branchId])
  @@index([patientId])
  @@index([doctorId])
}

model TreatmentPlan {
  id              String          @id @default(cuid())
  patientId       String
  doctorId        String
  toothNumber     String?
  treatmentType   String
  description     String?
  estimatedFee    Decimal         @db.Decimal(12, 2)
  status          TreatmentStatus @default(PROPOSED)
  plannedAt       DateTime        @default(now())
  organizationId  String
  branchId        String
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User            @relation("DoctorPlans", fields: [doctorId], references: [id], onDelete: Restrict)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([patientId])
  @@index([doctorId])
}

model Treatment {
  id              String          @id @default(cuid())
  patientId       String
  doctorId        String
  toothNumber     String?
  treatmentType   String
  description     String?
  fee             Decimal         @db.Decimal(12, 2)
  paymentPlan     Json?
  status          TreatmentStatus @default(STARTED)
  performedAt     DateTime        @default(now())
  organizationId  String
  branchId        String
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User            @relation("DoctorTreatments", fields: [doctorId], references: [id], onDelete: Restrict)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  payments        Payment[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([patientId])
  @@index([doctorId])
}

model Payment {
  id              String        @id @default(cuid())
  patientId       String?
  treatmentId     String?
  type            PaymentType
  amount          Decimal       @db.Decimal(12, 2)
  listAmount      Decimal?      @db.Decimal(12, 2)
  discountAmount  Decimal?      @db.Decimal(12, 2)
  referralSource  String?
  method          PaymentMethod
  description     String?
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime      @default(now())
  dueDate         DateTime?
  organizationId  String
  branchId        String
  patient         Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  treatment       Treatment?    @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId, paidAt])
  @@index([branchId])
  @@index([patientId])
  @@index([status])
}

model Invoice {
  id              String        @id @default(cuid())
  number          String        @unique
  patientId       String?
  paymentId       String?
  total           Decimal       @db.Decimal(12, 2)
  status          InvoiceStatus @default(DRAFT)
  providerRef     String?
  issuedAt        DateTime?
  organizationId  String
  branchId        String
  patient         Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  payment         Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([status])
}

model StockItem {
  id              String          @id @default(cuid())
  name            String
  category        String
  currentQuantity Int
  minimumQuantity Int
  unit            String
  supplier        String?
  purchasePrice   Decimal         @db.Decimal(12, 2)
  organizationId  String
  branchId        String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  movements       StockMovement[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([organizationId])
  @@index([branchId])
}

model StockMovement {
  id              String            @id @default(cuid())
  itemId          String
  type            StockMovementType
  quantity        Int
  note            String?
  movedAt         DateTime          @default(now())
  organizationId  String
  branchId        String
  item            StockItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([itemId])
}

model Staff {
  id              String         @id @default(cuid())
  fullName        String
  roleLabel       String
  phone           String?
  email           String?
  workingHours    String?
  compensation    String?
  active          Boolean        @default(true)
  organizationId  String
  branchId        String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  doctorProfile   DoctorProfile?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([branchId])
}

model DoctorProfile {
  id                String   @id @default(cuid())
  staffId           String   @unique
  specialty         String
  room              String?
  satisfactionScore Decimal  @db.Decimal(4, 2)
  weeklySchedule    Json
  staff             Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Consent {
  id              String        @id @default(cuid())
  patientId       String
  templateName    String
  content         String
  status          ConsentStatus @default(DRAFT)
  timestamp       DateTime      @default(now())
  signedAt        DateTime?
  organizationId  String
  branchId        String
  patient         Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([patientId])
}

model Survey {
  id              String           @id @default(cuid())
  title           String
  description     String?
  active          Boolean          @default(true)
  organizationId  String
  branchId        String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  responses       SurveyResponse[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([branchId])
}

model SurveyResponse {
  id              String       @id @default(cuid())
  surveyId        String
  patientId       String
  treatmentId     String?
  packageId       String?
  surveyTemplateId String?
  score           Int
  rating          Int?
  comment         String?
  answersJson     Json?
  npsScore        Int?
  submittedAt     DateTime?
  source          TourismSurveySource?
  followUpNeeded  Boolean      @default(false)
  organizationId  String
  branchId        String
  survey          Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  patient         Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([patientId])
  @@index([packageId])
}

model CommunicationLog {
  id              String              @id @default(cuid())
  patientId       String?
  channel         CommunicationChannel
  direction       CommunicationDirection @default(OUTBOUND)
  subject         String?
  source          String?
  contactName     String?
  contactValue    String?
  message         String
  status          CommunicationStatus @default(QUEUED)
  provider        String?
  providerRef     String?
  organizationId  String
  branchId        String
  patient         Patient?            @relation(fields: [patientId], references: [id], onDelete: SetNull)
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([organizationId])
  @@index([organizationId, direction])
  @@index([branchId])
  @@index([patientId])
  @@index([channel])
}

model Recall {
  id              String       @id @default(cuid())
  patientId       String
  reason          String
  dueDate         DateTime
  status          RecallStatus @default(OPEN)
  notes           String?
  organizationId  String
  branchId        String
  patient         Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([dueDate])
}

model ReportSnapshot {
  id              String       @id @default(cuid())
  type            String
  title           String
  payload         Json
  periodStart     DateTime
  periodEnd       DateTime
  organizationId  String
  branchId        String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([branchId])
}

model DemoRequest {
  id              String        @id @default(cuid())
  fullName        String
  clinicName      String
  phone           String
  email           String
  city            String
  clinicSize      String
  message         String?
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
}

model AuditLog {
  id              String        @id @default(cuid())
  userId          String?
  action          String
  module          String
  entityId        String?
  metadata        Json?
  ip              String?
  userAgent       String?
  organizationId  String
  branchId        String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([userId])
  @@index([module])
}

model Lead {
  id                  String                   @id @default(cuid())
  organizationId      String
  branchId            String?
  sourceChannel       TourismLeadSourceChannel
  fullName            String
  phone               String?
  email               String?
  country             String
  city                String?
  language            String                   @default("EN")
  interestedTreatment String
  estimatedBudget     String?
  travelDate          DateTime?
  message             String
  leadStatus          TourismLeadStatus        @default(NEW)
  leadScore           Int                      @default(50)
  assignedToUserId    String?
  lastContactAt       DateTime?
  nextFollowUpAt      DateTime?
  gdprConsent         Boolean                  @default(false)
  notes               String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([sourceChannel])
  @@index([leadStatus])
  @@index([country])
  @@index([phone])
  @@index([email])
}

model LeadMessage {
  id             String                 @id @default(cuid())
  leadId         String
  organizationId String
  branchId       String?
  direction      CommunicationDirection @default(INBOUND)
  channel        CommunicationChannel
  source         String?
  subject        String?
  message        String
  createdByUserId String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([leadId])
  @@index([channel])
}

model TourismPackage {
  id                 String               @id @default(cuid())
  organizationId     String
  branchId           String?
  leadId             String
  patientId          String?
  publicToken        String               @unique
  packageTitle       String
  treatmentSummary   String
  hotelInfo          String?
  transferInfo       String?
  arrivalAirport     String?
  arrivalDate        DateTime?
  departureDate      DateTime?
  numberOfCompanions Int                  @default(0)
  totalTreatmentPrice Decimal             @db.Decimal(12, 2)
  hotelPrice         Decimal              @db.Decimal(12, 2)
  transferPrice      Decimal              @db.Decimal(12, 2)
  discount           Decimal              @db.Decimal(12, 2)
  finalPrice         Decimal              @db.Decimal(12, 2)
  currency           TourismCurrency      @default(EUR)
  packageStatus      TourismPackageStatus @default(DRAFT)
  validUntil         DateTime?
  notes              String?
  createdByUserId    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([organizationId])
  @@index([branchId])
  @@index([leadId])
  @@index([packageStatus])
}

model TreatmentPackageItem {
  id                String   @id @default(cuid())
  packageId         String
  organizationId    String
  treatmentName     String
  toothArea         String?
  quantity          Int      @default(1)
  unitPrice         Decimal  @db.Decimal(12, 2)
  totalPrice        Decimal  @db.Decimal(12, 2)
  estimatedDuration String?
  explanation       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
  @@index([packageId])
}

model HotelPartner {
  id             String          @id @default(cuid())
  organizationId String
  branchId       String?
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  city           String
  district       String?
  address        String?
  starRating     Int?
  pricePerNight  Decimal         @db.Decimal(12, 2)
  currency       TourismCurrency @default(EUR)
  notes          String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@index([active])
}

model TransferPartner {
  id             String          @id @default(cuid())
  organizationId String
  branchId       String?
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  vehicleTypes   Json
  airportList    Json
  basePrice      Decimal         @db.Decimal(12, 2)
  currency       TourismCurrency @default(EUR)
  notes          String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@index([active])
}

model ReservationShare {
  id                String                 @id @default(cuid())
  organizationId    String
  branchId          String?
  packageId         String
  leadId            String
  hotelPartnerId    String?
  transferPartnerId String?
  sharedVia         ReservationShareChannel @default(N8N)
  payloadJson       Json
  status            ReservationShareStatus @default(PENDING)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([organizationId])
  @@index([packageId])
  @@index([leadId])
  @@index([status])
}

model FollowUpSequence {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  name           String
  description    String?
  active         Boolean  @default(true)
  stepsJson      Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([active])
}

model LeadFollowUp {
  id             String             @id @default(cuid())
  organizationId String
  branchId       String?
  leadId         String
  sequenceId     String
  currentStep    Int                @default(0)
  nextRunAt      DateTime
  status         LeadFollowUpStatus @default(ACTIVE)
  lastMessageAt  DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId])
  @@index([leadId])
  @@index([status])
  @@index([nextRunAt])
}

model PostTreatmentFollowUp {
  id               String                      @id @default(cuid())
  organizationId   String
  branchId         String?
  patientId        String
  treatmentId      String?
  packageId        String?
  publicToken      String                      @unique
  returnCountry    String
  returnDate       DateTime
  followUpDay      Int
  nextMessageAt    DateTime
  status           PostTreatmentFollowUpStatus @default(SCHEDULED)
  issueReported    Boolean                     @default(false)
  issueDescription String?
  painLevel        Int?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([organizationId])
  @@index([patientId])
  @@index([packageId])
  @@index([status])
}

model ReviewRequest {
  id              String              @id @default(cuid())
  organizationId  String
  branchId        String?
  patientId       String
  treatmentId     String?
  packageId       String?
  platform        ReviewPlatform
  reviewLink      String
  scheduledAt     DateTime
  sentAt          DateTime?
  status          ReviewRequestStatus @default(SCHEDULED)
  language        String              @default("EN")
  messageTemplate String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([organizationId])
  @@index([patientId])
  @@index([packageId])
  @@index([status])
}

model BeforeAfterCase {
  id             String            @id @default(cuid())
  organizationId String
  branchId       String?
  patientId      String
  treatmentType  String
  title          String
  description    String?
  beforeImageUrl String
  afterImageUrl  String
  consentGiven   Boolean           @default(false)
  consentId      String?
  country        String?
  ageRange       String?
  gender         String?
  tags           Json?
  privacyNotes   String?
  status         BeforeAfterStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([patientId])
  @@index([treatmentType])
  @@index([status])
}

model ConsentTemplate {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  title          String
  language       String
  content        String
  treatmentType  String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([language])
  @@index([active])
}

model DigitalConsent {
  id              String               @id @default(cuid())
  organizationId  String
  branchId        String?
  patientId       String?
  leadId          String?
  templateId      String
  title           String
  contentSnapshot String
  language        String
  publicToken     String               @unique
  status          DigitalConsentStatus @default(DRAFT)
  signedAt        DateTime?
  signerName      String?
  signerIp        String?
  signerUserAgent String?
  signatureData   String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([organizationId])
  @@index([patientId])
  @@index([leadId])
  @@index([status])
}

model SurveyTemplate {
  id             String   @id @default(cuid())
  organizationId String
  branchId       String?
  title          String
  language       String
  questionsJson  Json
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([language])
  @@index([active])
}

model ChatbotKnowledgeBase {
  id             String          @id @default(cuid())
  organizationId String
  branchId       String?
  question       String
  answer         String
  language       String
  category       ChatbotCategory
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@index([language])
  @@index([category])
}

model ChatConversation {
  id             String                    @id @default(cuid())
  organizationId String
  branchId       String?
  leadId         String?
  channel        ChatConversationChannel
  language       String
  status         ChatConversationStatus    @default(BOT_HANDLED)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([organizationId])
  @@index([leadId])
  @@index([status])
}

model ChatMessage {
  id             String            @id @default(cuid())
  organizationId String
  conversationId String
  sender         ChatMessageSender
  message        String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([conversationId])
}

model Notification {
  id             String           @id @default(cuid())
  organizationId String
  userId         String?
  title          String
  message        String
  type           NotificationType
  read           Boolean          @default(false)
  actionUrl      String?
  createdAt      DateTime         @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([read])
  @@index([type])
}

model Task {
  id               String       @id @default(cuid())
  organizationId   String
  branchId         String?
  assignedToUserId String?
  relatedLeadId    String?
  relatedPatientId String?
  title            String
  description      String?
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(TODO)
  dueDate          DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
  @@index([assignedToUserId])
  @@index([relatedLeadId])
  @@index([status])
  @@index([priority])
}

model IntegrationLog {
  id             String               @id @default(cuid())
  organizationId String
  branchId       String?
  provider       IntegrationProvider
  eventType      String
  payloadJson    Json
  responseJson   Json?
  status         IntegrationLogStatus @default(SUCCESS)
  errorMessage   String?
  createdAt      DateTime             @default(now())

  @@index([organizationId])
  @@index([provider])
  @@index([status])
  @@index([eventType])
}

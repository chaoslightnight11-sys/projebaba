NODE_ENV="production"
DATABASE_URL="postgresql://clinicnova:REPLACE_WITH_STRONG_PASSWORD@db.example.com:5432/clinicnova?schema=public&sslmode=require"
AUTH_SECRET="REPLACE_WITH_AT_LEAST_48_RANDOM_CHARACTERS"
AUTH_COOKIE_SECURE="true"
NEXT_PUBLIC_APP_URL="https://app.example.com"
DEMO_MODE="false"
ALLOW_PRODUCTION_DEMO="false"
CRON_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
N8N_WEBHOOK_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
N8N_OUTBOUND_WEBHOOK_URL="https://automation.example.com/webhook/clinicnova-outbound"
N8N_OUTBOUND_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
REQUIRE_LIVE_INTEGRATIONS="true"
FILE_STORAGE_ROOT="/var/lib/clinicnova/patient-files"
FILE_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"
FILE_ENCRYPTION_KEYS='{"2026-01":"REPLACE_WITH_32_BYTE_BASE64_KEY"}'
FILE_ENCRYPTION_ACTIVE_KEY_ID="2026-01"
MFA_ENCRYPTION_KEY="REPLACE_WITH_SEPARATE_32_BYTE_BASE64_KEY"
MFA_ENCRYPTION_KEYS='{"2026-01":"REPLACE_WITH_SEPARATE_32_BYTE_BASE64_KEY"}'
MFA_ENCRYPTION_ACTIVE_KEY_ID="2026-01"
FILE_AV_REQUIRED="true"
FILE_AV_COMMAND="clamscan"
PITR_ENABLED="true"
BACKUP_REMOTE="rclone-remote:clinicnova-production"
RESTORE_TEST_SCHEDULED="true"
AUDIT_ANCHOR_KEY="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
AUDIT_ANCHOR_REMOTE="rclone-remote:clinicnova-audit"
OPS_ALERT_WEBHOOK_URL="https://automation.example.com/webhook/clinicnova-ops-alert"
OPS_ALERT_WEBHOOK_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS"
BACKUP_ROOT="/var/backups/clinicnova"
BACKUP_MAX_AGE_HOURS="30"
DISK_ALERT_PERCENT="85"
MOBILE_MIN_VERSION="1.2.0"
MOBILE_APK_URL="https://download.example.com/ClinicNova-1.2.0.apk"
MOBILE_APK_SHA256="REPLACE_AFTER_SIGNING"

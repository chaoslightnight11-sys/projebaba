{
  "name": "clinicnova",
  "version": "1.15.1",
  "private": true,
  "description": "ClinicNova - production-gated dental clinic management platform",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev",
    "webview": "node scripts/webview.mjs",
    "build": "next build && node scripts/build-web-demo.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:integration": "tsx scripts/test-postgres-integration.ts",
    "test:e2e": "playwright test",
    "android:build": "bash scripts/build-android-apk.sh",
    "android:verify": "apksigner verify --verbose --print-certs releases/ClinicNova-$(node -p \"require('./package.json').version\").apk",
    "ios:demo": "node scripts/build-ios-demo.mjs",
    "ios:prepare": "node scripts/build-ios-app-assets.mjs",
    "ios:build": "bash scripts/build-ios-app.sh",
    "build:web-demo": "node scripts/build-web-demo.mjs",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "production:check": "NODE_ENV=production node --import tsx scripts/check-production-env.ts",
    "prisma:deploy": "prisma migrate deploy",
    "start:production": "npm run production:check && npm run prisma:deploy && next start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "clinic:bootstrap": "tsx scripts/bootstrap-clinic.ts",
    "clinic:secrets": "node scripts/generate-clinic-secrets.mjs",
    "clinic:package": "bash scripts/prepare-clinic-package.sh",
    "desktop:prepare": "node scripts/build-desktop-assets.mjs",
    "desktop:win": "npm run desktop:prepare && electron-builder --projectDir desktop/app --config ../../electron-builder.yml --win nsis --x64",
    "desktop:mac": "npm run desktop:prepare && electron-builder --projectDir desktop/app --config ../../electron-builder.yml --mac dmg --universal",
    "files:migrate": "tsx scripts/migrate-patient-files-to-storage.ts",
    "files:rotate-key": "tsx scripts/rotate-file-encryption-key.ts",
    "mfa:rotate-key": "tsx scripts/rotate-mfa-encryption-key.ts",
    "audit:verify": "tsx scripts/verify-audit-chain.ts",
    "ops:check": "tsx scripts/ops-health-check.ts",
    "test:load": "tsx scripts/load-smoke.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "bonjour-service": "1.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "jose": "^5.6.3",
    "lucide-react": "^0.468.0",
    "next": "15.5.20",
    "next-themes": "^0.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "recharts": "^2.12.7",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.12",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.20",
    "postcss": "8.5.16",
    "prisma": "^5.17.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
